{
  "_comment": "Example permission allowlist for econstack skills. Copy to .claude/settings.json (project-level) or merge into ~/.claude/settings.json (user-level) to stop Claude Code from prompting on every R/Python/Quarto tool call. Driven by OBR feedback that constant permission prompts blocked background runs of /fiscal-briefing and /macro-briefing.",
  "permissions": {
    "allow": [
      "Bash(Rscript:*)",
      "Bash(R:*)",
      "Bash(quarto:*)",
      "Bash(quarto render:*)",
      "Bash(pandoc:*)",
      "Bash(python3:*)",
      "Bash(uv:*)",
      "Bash(jq:*)",
      "Bash(curl -fsSL:*)",
      "Bash(wget -q:*)",
      "Bash(./scripts/*)",
      "Bash(~/.claude/skills/econstack/bin/*)",
      "Bash(echo:*)",
      "Bash(date:*)",
      "Bash(test -f:*)",
      "Bash(test -d:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(mkdir -p:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "WebFetch(domain:obr.uk)",
      "WebFetch(domain:ons.gov.uk)",
      "WebFetch(domain:hmrc.gov.uk)",
      "WebFetch(domain:gov.uk)",
      "WebFetch(domain:bankofengland.co.uk)",
      "WebFetch(domain:imf.org)",
      "WebFetch(domain:oecd.org)",
      "WebFetch(domain:cbo.gov)",
      "WebFetch(domain:treasury.gov)",
      "WebFetch(domain:bea.gov)",
      "WebFetch(domain:bls.gov)",
      "WebFetch(domain:fred.stlouisfed.org)",
      "WebFetch(domain:abs.gov.au)",
      "WebFetch(domain:rba.gov.au)",
      "WebFetch(domain:treasury.gov.au)",
      "WebFetch(domain:pbo.gov.au)",
      "WebFetch(domain:ec.europa.eu)",
      "WebFetch(domain:ecb.europa.eu)",
      "WebFetch(domain:eurostat.ec.europa.eu)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/credentials*)",
      "Write(**/*.pem)",
      "Write(**/*.key)"
    ]
  }
}
